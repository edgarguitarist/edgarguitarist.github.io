---
import { getUI, format } from "@i18n/ui";
import { getProfile, yearsSince } from "@lib/profile";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";

const ui = getUI(Astro.currentLocale);
const currentLang = Astro.currentLocale;

// Años de experiencia (misma fuente que el contador del Aboutme): la meta
// description y el JSON-LD se generan dinámicamente para no quedar desfasados.
const profile = await getProfile();
const years = yearsSince(profile.created_at);
const siteDescription = format(ui.site.description, [years]);
const langOptions = [
  { code: "en", path: "/", label: "English" },
  { code: "es", path: "/es", label: "Español" },
];

// --- SEO: URLs canónicas / alternativas por idioma (sitio bilingüe en/es) ---
const SITE = "https://edgarguitarist.github.io";
const isEs = currentLang === "es";
const urlEn = `${SITE}/`;
const urlEs = `${SITE}/es/`;
const canonical = isEs ? urlEs : urlEn;
const ogLocale = isEs ? "es_ES" : "en_US";
const ogLocaleAlt = isEs ? "en_US" : "es_ES";
const ogImage = isEs ? `${SITE}/images/og-image-es.png` : `${SITE}/images/og-image.png`;

// Resumen profesional para IA/buscadores (schema.org description), por idioma.
const personDescription = isEs
  ? `Desarrollador de Software Full-Stack con más de ${years} años de experiencia construyendo sistemas web y aplicaciones móviles. Experiencia liderando equipos de desarrollo (Lead / Senior). Especializado en Angular, React, Node.js y .NET, con integraciones de IA. Bilingüe (español e inglés), abierto a nuevas oportunidades remotas o presenciales.`
  : `Full-Stack Software Developer with ${years}+ years of experience building web systems and mobile apps. Proven experience leading development teams (Lead / Senior roles). Specialized in Angular, React, Node.js and .NET, with AI integrations. Bilingual (Spanish and English), open to new remote or on-site opportunities.`;

// Datos estructurados schema.org/Person (rich results / knowledge graph / IA).
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Edgar Mariano Laz Terán",
  alternateName: "Edgar Laz",
  url: SITE,
  image: ogImage,
  jobTitle: isEs ? "Desarrollador de Software Full-Stack" : "Full-Stack Software Developer",
  description: personDescription,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Guayaquil",
    addressCountry: "EC",
  },
  email: "mailto:edgarguitarist+contacto@gmail.com",
  knowsLanguage: ["Spanish", "English"],
  knowsAbout: [
    "Angular",
    "React",
    "Node.js",
    "TypeScript",
    "JavaScript",
    ".NET",
    "C#",
    "Python",
    "PHP",
    "Java",
    "Kotlin",
    "Astro",
    "Next.js",
    "Express",
    "TailwindCSS",
    "Docker",
    "SQL Server",
    "PostgreSQL",
    "MySQL",
    "MongoDB",
    "Full-Stack Web Development",
    "Mobile App Development",
    "AI Integration",
  ],
  sameAs: [
    "https://www.github.com/edgarguitarist",
    "https://www.linkedin.com/in/edgarlteran/",
    "https://x.com/edgarguitarist",
    "https://www.instagram.com/edgarguitarist/",
  ],
};
---

<!DOCTYPE html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="google-site-verification"
      content="f9HeFD7WwMgQdu6Psy-8J_GUh4na3a-jXKh99vF7A7k"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.github.com" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      />
    </noscript>
    <meta name="theme-color" content="#0a0a0f" />
    <meta name="description" content={siteDescription} />
    <meta
      name="keywords"
      content="Edgar Laz, Portfolio Edgar Laz, Edgar Mariano Laz Terán, Software Developer, Full Stack Developer, Angular Developer, React Developer, edgarguitarist"
    />
    <meta name="author" content="Edgar Mariano Laz Terán" />
    <meta name="robots" content="index,follow" />

    <!-- Canonical + alternates de idioma (hreflang) -->
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={urlEn} />
    <link rel="alternate" hreflang="es" href={urlEs} />
    <link rel="alternate" hreflang="x-default" href={urlEn} />

    <!-- Open Graph -->
    <meta property="og:title" content={ui.site.title} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Edgar Mariano Laz Terán" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Edgar Mariano Laz Terán — Software Developer" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@edgarguitarist" />
    <meta name="twitter:creator" content="@edgarguitarist" />
    <meta name="twitter:title" content={ui.site.title} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="generator" content={Astro.generator} />
    <title>{ui.site.title}</title>

    <!-- Datos estructurados: Person -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(personLd)}
    />
  </head>

  <body class="dark:bg-[#0a0a0f] bg-gray-50 transition-colors duration-300 noise">
    <Navbar username="edgarguitarist">
      <div
        class="inline-flex items-center gap-0.5 rounded-full border p-0.5 text-xs font-bold dark:border-white/15 border-black/10 dark:bg-white/5 bg-black/[0.04]"
        role="group"
        aria-label="Language"
      >
        {
          langOptions.map((lang) => (
            <a
              href={lang.path}
              aria-label={lang.label}
              aria-current={lang.code === currentLang ? "true" : undefined}
              class:list={[
                "px-2.5 py-1 rounded-full transition-all duration-200",
                lang.code === currentLang
                  ? "bg-gradient-to-r from-purple-500 to-pink-500 text-white shadow-sm"
                  : "dark:text-gray-400 text-gray-600 hover:dark:text-white hover:text-gray-900",
              ]}
            >
              {lang.code.toUpperCase()}
            </a>
          ))
        }
      </div>
    </Navbar>
    <main
      class="relative m-auto px-6 lg:px-10 lg:max-w-screen-xl max-w-full z-10 text-center pt-14 pb-20"
    >
      <slot />
    </main>
    <Footer />
    <script>
      // Refresca el perfil (empresa, ubicación, nombre) EN VIVO desde GitHub,
      // por encima de los valores obtenidos en build. Actualiza [data-gh].
      fetch("https://api.github.com/users/edgarguitarist")
        .then((r) => (r.ok ? r.json() : null))
        .then((u) => {
          if (!u) return;
          const set = (key: string, val: string) => {
            if (!val) return;
            document
              .querySelectorAll(`[data-gh="${key}"]`)
              .forEach((el) => (el.textContent = val));
          };
          set("name", u.name);
          set("company", u.company);
          set("location", u.location);
        })
        .catch(() => {});
    </script>
  </body>
</html>
