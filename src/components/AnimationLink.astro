---

<img
  id="link"
  src="/images/link.webp"
  class="pointer-events-none absolute right-6 md:right-12 -top-[70px] z-40 h-[75px] hidden sm:block"
  alt="link"
/>

<script>
  const link = document.getElementById("link") as HTMLImageElement;
  const toggleAnimation = (e: any) => {
    link.src = e.type !== "mouseover" ? "/images/link.webp" : "/images/link-2.webp";
  };

  link.addEventListener("mouseover", toggleAnimation);
  link.addEventListener("mouseout", toggleAnimation);
</script>
