---
export interface Job {
  company: string;
  position: string;
  location: string;
  period: string;
  current: boolean;
  description: string;
  tech: string[];
}

const { job, currentLabel } = Astro.props as { job: Job; currentLabel: string };
---

<div
  class="experience-card group relative h-full flex flex-col p-4 md:p-5 rounded-2xl backdrop-blur-sm border border-white/10 dark:bg-white/5 bg-gray-50/80 hover:border-purple-500/30 transition-all duration-300 hover:shadow-[0_0_30px_rgba(116,58,213,0.1)]"
>
  {
    job.current && (
      <span class="absolute -top-3 right-4 px-3 py-1 text-xs font-bold rounded-full bg-gradient-to-r from-green-400 to-emerald-500 text-white shadow-lg whitespace-nowrap">
        {currentLabel}
      </span>
    )
  }

  <div class="text-left mb-3">
    <h3 class="text-lg md:text-xl font-bold dark:text-white text-gray-900 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-purple-400 group-hover:to-pink-400 transition-all duration-300">
      {job.company}
    </h3>
    <p class="dark:text-purple-400 text-purple-600 font-semibold text-sm mt-1">{job.position}</p>
  </div>

  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm dark:text-gray-400 text-gray-500 mb-4">
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
      {job.location}
    </span>
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
      {job.period}
    </span>
  </div>

  <p class="dark:text-gray-300 text-gray-600 text-sm leading-relaxed text-left mb-4">
    {job.description}
  </p>

  <div class="flex flex-wrap gap-2 mt-auto">
    {
      job.tech.map((tech: string) => (
        <span class="px-3 py-1 text-xs font-medium rounded-full dark:bg-purple-500/10 bg-purple-100 dark:text-purple-300 text-purple-700 border dark:border-purple-500/20 border-purple-200">
          {tech}
        </span>
      ))
    }
  </div>
</div>
