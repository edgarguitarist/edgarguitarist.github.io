---
import { getUI } from "@i18n/ui";
import { Info } from "../types/global.types";
import ButtonSocials from "./buttons/ButtonSocials.astro";
import AnimationLink from "./AnimationLink.astro";
import me from "@db/user.json";

import Github from "@icons/github.astro";
import Linkedin from "@icons/linkedin.astro";
import Document from "@icons/document.astro";
const iconStyle = "m-auto w-3/5 h-3/5 hover:transform hover:scale-105";
const ui = getUI(Astro.currentLocale);
const year = new Date().getFullYear();
---

<footer
  class="relative z-10 w-full dark:bg-[#0a0a0f]/80 bg-white/80 backdrop-blur-xl border-t dark:border-white/10 border-black/[0.06]"
>
  <!-- Línea de acento -->
  <div
    class="h-px w-full bg-gradient-to-r from-transparent via-purple-500/60 to-transparent"
  >
  </div>

  <div
    class="max-w-screen-xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4"
  >
    <!-- Powered with -->
    <p
      class="flex items-center gap-1.5 text-sm dark:text-gray-400 text-gray-500"
    >
      {ui.index.footer.developer}
      <strong class="gradient-text font-bold">{me.name}</strong>
      <span class="dark:text-gray-600 text-gray-400">·</span>
      {ui.index.footer.using}
      <img
        src="/svg/astro-logo-light.svg"
        alt="Astro"
        class="h-5 dark:brightness-100 brightness-0"
      />
    </p>

    <!-- Sociales + copyright -->
    <div class="flex items-center gap-4">
      <span class="hidden md:inline text-xs dark:text-gray-600 text-gray-400"
        >© {year}</span
      >
      <div class="flex items-center gap-3">
        <ButtonSocials social={Info.linkedin}>{<Linkedin class={iconStyle} />}</ButtonSocials>
        <ButtonSocials social={Info.github}>{<Github class={iconStyle} />}</ButtonSocials>
        <ButtonSocials social={Info.pdf2}>{<Document class={iconStyle} />}</ButtonSocials>
      </div>
    </div>
  </div>

  <!-- Sprite decorativo asomándose sobre el borde -->
  <AnimationLink />
</footer>
