---
import langs from "@data/langs.json";
import dbs from "@data/dbs.json";
import libs from "@data/libs.json";
import KnowledgeCard from "@components/cards/knowledgeCard.astro";
import type {
  KnowDicInterface,
  KnowInterface,
  Knowledge,
} from "../../types/global.types";
import { getUI } from "@i18n/ui";

interface Props extends KnowInterface {}

const { section }: { section: Knowledge } = Astro.props;
const ui = getUI(Astro.currentLocale);

const knowDic: KnowDicInterface = {
  PL: {
    title: ui.index.knowledge.section1,
    data: langs,
  },
  SGBD: {
    title: ui.index.knowledge.section2,
    data: dbs,
  },
  FW: {
    title: ui.index.knowledge.section3,
    data: libs,
  },
};
---

<div class="mt-8" id={section}>
  <h2 class="font-bold dark:text-gray-300 text-gray-700 text-lg tracking-wider uppercase">
    {knowDic[section].title}
  </h2>
  <div class="grid grid-cols-4 sm:grid-cols-6 lg:grid-cols-8 justify-items-center my-6 w-fit mx-auto gap-2 md:gap-4">
    {
      knowDic[section].data
        .filter((data) => data.show)
        .map((data) => (
          <KnowledgeCard src={data.src} name={data.name} />
        ))
    }
  </div>
</div>
